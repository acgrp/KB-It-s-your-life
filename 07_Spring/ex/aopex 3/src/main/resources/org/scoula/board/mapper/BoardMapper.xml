<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.scoula.board.mapper.BoardMapper">

    <!-- ============================================================
         게시글 ResultMap
    ============================================================ -->
    <resultMap id="boardResultMap" type="org.scoula.board.dto.BoardDTO">
        <id     property="id"         column="id"/>
        <result property="title"      column="title"/>
        <result property="content"    column="content"/>
        <result property="writer"     column="writer"/>
        <result property="regDate"    column="reg_date"/>
        <result property="updateDate" column="update_date"/>
    </resultMap>

    <!-- 첨부파일 ResultMap (BLOB 컬럼 포함) -->
    <resultMap id="attachmentResultMap" type="org.scoula.board.dto.AttachmentDTO">
        <id     property="id"          column="id"/>
        <result property="boardId"     column="board_id"/>
        <result property="filename"    column="filename"/>
        <result property="contentType" column="content_type"/>
        <result property="fileSize"    column="file_size"/>
        <result property="fileData"    column="file_data" jdbcType="BLOB"/>
    </resultMap>

    <!-- 첨부파일 메타만 조회할 때 (BLOB 제외) -->
    <resultMap id="attachmentMetaResultMap" type="org.scoula.board.dto.AttachmentDTO">
        <id     property="id"          column="id"/>
        <result property="boardId"     column="board_id"/>
        <result property="filename"    column="filename"/>
        <result property="contentType" column="content_type"/>
        <result property="fileSize"    column="file_size"/>
        <!-- file_data 는 의도적으로 제외 -->
    </resultMap>

    <!-- ============================================================
         게시글 CRUD
    ============================================================ -->
    <select id="selectAll" resultMap="boardResultMap">
        SELECT id, title, content, writer, reg_date, update_date
        FROM board
        ORDER BY id DESC
    </select>

    <select id="selectById" parameterType="long" resultMap="boardResultMap">
        SELECT id, title, content, writer, reg_date, update_date
        FROM board
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="org.scoula.board.dto.BoardDTO"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO board (title, content, writer, reg_date, update_date)
        VALUES (#{title}, #{content}, #{writer}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="org.scoula.board.dto.BoardDTO">
        UPDATE board
        SET title       = #{title},
            content     = #{content},
            update_date = NOW()
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM board WHERE id = #{id}
    </delete>

    <!-- ============================================================
         첨부파일 BLOB CRUD
    ============================================================ -->

    <!--
        파일 데이터(BLOB)를 DB에 저장.
        jdbcType="BLOB" 지정 필수 – MyBatis가 byte[]를 BLOB으로 인식.
    -->
    <insert id="insertAttachment" parameterType="org.scoula.board.dto.AttachmentDTO"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO board_attachment (board_id, filename, content_type, file_size, file_data)
        VALUES (#{boardId}, #{filename}, #{contentType}, #{fileSize},
                #{fileData, jdbcType=BLOB})
    </insert>

    <!-- 목록 조회: BLOB 제외 (성능 고려) -->
    <select id="selectAttachmentsByBoardId" parameterType="long"
            resultMap="attachmentMetaResultMap">
        SELECT id, board_id, filename, content_type, file_size
        FROM board_attachment
        WHERE board_id = #{boardId}
        ORDER BY id
    </select>

    <!-- 단건 조회: BLOB 포함 (다운로드 전용) -->
    <select id="selectAttachmentById" parameterType="long"
            resultMap="attachmentResultMap">
        SELECT id, board_id, filename, content_type, file_size, file_data
        FROM board_attachment
        WHERE id = #{id}
    </select>

    <delete id="deleteAttachment" parameterType="long">
        DELETE FROM board_attachment WHERE id = #{id}
    </delete>

    <delete id="deleteAttachmentsByBoardId" parameterType="long">
        DELETE FROM board_attachment WHERE board_id = #{boardId}
    </delete>

</mapper>
